# Copy to .env and fill in real values. .env is git-ignored.
# Load with: set -a; source .env; set +a

# --- Databricks (用于 SLM/download_v7_grounded.py 拉数据) ---
# 通过 az 登录后用 AAD token (TTL 1h):
#   az account get-access-token --resource 2ff814a6-3304-4ab8-85cb-cd0e6f879c1d \
#       --query accessToken -o tsv > aad_token
# 然后:
DATABRICKS_TOKEN=

# --- GitHub (仅在跑 1.sh 推代码时需要) ---
# https://github.com/settings/tokens  -> classic, scope: repo
GITHUB_TOKEN=
GITHUB_USER=hufeishaoxia

# --- Cosmos (仅 upload_v7_grounded_to_cosmos.py 需要) ---
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=doca
COSMOS_CONTAINER=
PARTITION_KEY=conversation_id

# --- W&B (默认 offline, 不需要 key) ---
WANDB_MODE=offline
# WANDB_API_KEY=
